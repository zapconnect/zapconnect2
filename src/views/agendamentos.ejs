<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Agendamentos • ZapConnect</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer">
  <link rel="icon" href="/img/favinco.png" />
  <link rel="stylesheet" href="/css/agendamentos.css">
</head>

<body data-user-tz="<%= user.timezone_offset || -180 %>" data-default-ddi="<%= user.default_ddi || '55' %>">

  <header class="topbar">
    <div class="brand">
      <i class="fa-solid fa-calendar-check"></i>
      <h1>Agendamentos</h1>
    </div>
    <a href="/painel" class="btn-back">
      <i class="fa-solid fa-arrow-left"></i>
      Voltar
    </a>
  </header>

  <main class="container">

    <!-- FORM -->
    <section class="card form">
      <h2><i class="fa-solid fa-plus"></i> Novo Agendamento</h2>

      <div class="form-grid">
        <div class="form-fields">
          <div class="field">
            <label><i class="fa-solid fa-earth-americas"></i> Fuso horário</label>
            <div class="two-cols">
              <select id="timezoneSelect">
                <option value="-180">(UTC-03:00) Brasília</option>
                <option value="-240">(UTC-04:00) Manaus</option>
                <option value="-120">(UTC-02:00) Fernando de Noronha</option>
                <option value="0">(UTC+00:00) Londres</option>
                <option value="60">(UTC+01:00) Lisboa</option>
                <option value="-300">(UTC-05:00) NY/EST</option>
              </select>
              <button class="btn-secondary" type="button" onclick="salvarTimezone()">Salvar fuso</button>
            </div>
            <small class="hint">Usado para interpretar data/hora dos agendamentos.</small>
          </div>
          <label>
            <i class="fa-solid fa-phone"></i>
            Lista de números
          </label>
          <div class="inline-actions">
            <button class="btn-secondary" onclick="document.getElementById('csvInput').click()">
              <i class="fa-solid fa-file-csv"></i>
              Importar CSV
            </button>
            <input type="file" id="csvInput" accept=".csv,text/csv" style="display:none" onchange="importarCSV(this)">
          </div>
          <textarea id="nums" rows="4" placeholder="<%= user.default_ddi || '55' %> (49) 99999-9999&#10;<%= user.default_ddi || '55' %> (11) 98888-8888" oninput="handleNumsInput()"></textarea>
          <div class="field-hint" id="num-count">0 números</div>
          <small class="hint">O campo aplica máscara automática e inicia cada linha com DDI <%= user.default_ddi || '55' %>.</small>

          <label>
            <i class="fa-solid fa-message"></i>
            Mensagem
          </label>
          <textarea id="msg" rows="3" placeholder="Digite a mensagem..." oninput="updatePreview()"></textarea>
          <small class="hint">
            Personalize com variáveis: {{nome}}, {{numero}}, {{data}}, {{hora}}, {{pedido}} ou qualquer coluna do CSV (ex.: {{email}}).
          </small>

          <label>
            <i class="fa-solid fa-paperclip"></i>
            Arquivo (opcional)
          </label>

          <!-- Input de arquivo real -->
          <div class="file-upload-area" id="fileUploadArea" onclick="document.getElementById('fileInput').click()">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span id="fileUploadLabel">Clique para selecionar imagem, vídeo, PDF ou áudio</span>
            <span class="file-upload-hint">Máximo 15MB</span>
          </div>
          <input type="file" id="fileInput"
            accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.zip,.txt"
            style="display:none"
            onchange="handleFileSelect(this)">

          <!-- Preview do arquivo -->
          <div id="filePreview" class="file-preview-area" style="display:none;">
            <img id="previewImg" style="display:none;" alt="preview">
            <div id="previewDoc" class="preview-doc" style="display:none;">
              <i class="fa-solid fa-file"></i>
              <span id="previewDocName"></span>
            </div>
            <button class="btn-remove-file" onclick="clearFile()" title="Remover arquivo">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>

          <div class="two-cols">
            <div class="field">
              <label>
                <i class="fa-solid fa-clock"></i>
                Data e Hora
              </label>
              <input type="datetime-local" id="sendAt">
            </div>
            <div class="field">
              <label>
                <i class="fa-solid fa-rotate"></i>
                Repetição
              </label>
              <select id="recurrence" onchange="toggleRecurrenceEnd()">
                <option value="none">Não repetir (único)</option>
                <option value="daily">Diario</option>
                <option value="weekly">Semanal</option>
                <option value="monthly">Mensal</option>
              </select>
            </div>
            <div class="field" id="recurrenceEndField" style="display:none;">
              <label>
                <i class="fa-solid fa-flag-checkered"></i>
                Encerrar recorrência em
              </label>
              <input type="date" id="recurrenceEnd">
              <small class="hint">Opcional. Último dia para repetir.</small>
            </div>
          </div>

          <button id="btnAgendar" class="btn-primary" onclick="agendar()">
            <i class="fa-solid fa-calendar-plus"></i>
            Agendar Mensagem
          </button>

          <p id="result"></p>
        </div>

        <div class="preview-card">
          <div class="preview-header">
            <i class="fa-solid fa-eye"></i> Prévia (estilo WhatsApp)
          </div>
          <div class="preview-chat">
            <div id="previewImage" class="chat-image" style="display:none;">
              <img src="" alt="arquivo de imagem">
            </div>
            <div id="previewFile" class="chat-file" style="display:none;">
              <i class="fa-solid fa-paperclip"></i>
              <span>Arquivo anexado</span>
            </div>
            <div class="chat-bubble">
              <span id="previewMessage">Sua mensagem aparecerá aqui</span>
              <span class="chat-time">agora</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LISTA -->
    <section class="card list">
      <h2><i class="fa-solid fa-list"></i> Agendamentos Criados</h2>

      <div class="filters">
        <div class="field">
          <label><i class="fa-solid fa-filter"></i> Status</label>
          <select id="statusFilter" onchange="resetPageAndLoad()">
            <option value="all">Todos</option>
            <option value="pending">Pendentes</option>
            <option value="sent">Enviados</option>
            <option value="failed">Falhos</option>
          </select>
        </div>
        <div class="field">
          <label><i class="fa-solid fa-magnifying-glass"></i> Buscar número ou mensagem</label>
          <input type="text" id="searchTerm" placeholder="54999 ou parte da mensagem" oninput="resetPageAndLoad()" />
        </div>
        <div class="field">
          <label><i class="fa-solid fa-calendar"></i> Período</label>
          <div class="date-range">
            <input type="date" id="dateFrom" onchange="resetPageAndLoad()">
            <span>à</span>
            <input type="date" id="dateTo" onchange="resetPageAndLoad()">
          </div>
        </div>
        <div class="field">
          <label><i class="fa-solid fa-arrow-down-wide-short"></i> Ordenar</label>
          <select id="orderBy" onchange="resetPageAndLoad()">
            <option value="send_at|desc">Data de envio (mais recente)</option>
            <option value="send_at|asc">Data de envio (mais antiga)</option>
            <option value="status|asc">Status (pendentes primeiro)</option>
            <option value="status|desc">Status (enviados primeiro)</option>
          </select>
        </div>
        <div class="field small">
          <label><i class="fa-solid fa-list-ol"></i> Por página</label>
          <select id="pageSize" onchange="resetPageAndLoad()">
            <option value="10">10</option>
            <option value="25">25</option>
            <option value="50">50</option>
          </select>
        </div>
      </div>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Número(s)</th>
              <th>Mensagem</th>
              <th>Data / Hora</th>
              <th>Falta</th>
              <th>Status</th>
              <th>Ação</th>
            </tr>
          </thead>
          <tbody id="agendamentosTable">
            <tr>
              <td colspan="6" class="loading">Carregando...</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="pagination">
        <button id="prevPage" class="btn-secondary" onclick="changePage(-1)">« Anterior</button>
        <span id="pageInfo">Página 1/1</span>
        <button id="nextPage" class="btn-secondary" onclick="changePage(1)">Próxima »</button>
      </div>
    </section>

  </main>

  <!-- Modal de confirmação -->
  <div id="confirmModal" class="modal hidden">
    <div class="modal-content">
      <h3><i class="fa-solid fa-clipboard-check"></i> Confirmar agendamento</h3>
      <ul class="summary-list">
        <li><span>Data e hora:</span> <strong id="summary-datetime">—</strong></li>
        <li><span>Quantidade:</span> <strong id="summary-qty">—</strong></li>
        <li><span>Recorrência:</span> <strong id="summary-recurrence">—</strong></li>
        <li><span>Mensagem:</span> <strong id="summary-message">—</strong></li>
        <li><span>Personalizadas:</span> <strong id="summary-personalized">—</strong></li>
        <li><span>Arquivo:</span> <strong id="summary-file">—</strong></li>
      </ul>
      <div class="modal-actions">
        <button id="btnConfirmModal" class="btn-primary">
          <i class="fa-solid fa-check"></i> Confirmar e agendar
        </button>
        <button id="btnCancelModal" class="btn-secondary" type="button">
          <i class="fa-solid fa-circle-xmark"></i> Voltar e editar
        </button>
      </div>
    </div>
  </div>

  <!-- Modal de detalhes -->
  <div id="detailsModal" class="modal hidden">
    <div class="modal-content">
      <h3><i class="fa-solid fa-list"></i> Histórico do agendamento</h3>
      <div id="detailsBody" class="details-body">Carregando...</div>
      <div class="modal-actions">
        <button class="btn-secondary" onclick="fecharDetalhes()">Fechar</button>
      </div>
    </div>
  </div>

  <script src="/js/loading-utils.js"></script>
  <script src="/js/toast.js"></script>
  <script>
    // ── Estado do arquivo selecionado ────────────────────────────────
    let selectedFileData = null; // { base64, filename, mimetype }
    let editingId = null;
    let existingFilename = null;
    let contactsData = [];
    const plan = "<%= (user.plan || 'starter').toLowerCase() %>";
    const MAX_NUMBERS = <%= Number(planConfig?.maxBroadcastNumbers ?? 50) %>;
    const WARN_THRESHOLD = 0.8; // 80%
    let agRows = [];
    let agPage = 1;
    let agTotalPages = 1;
    let USER_TZ = Number(document.body.dataset.userTz || -180); // minutos em relação ao UTC
    const PHONE_PREFIX = getConfiguredDefaultDdi();
    const PHONE_MIN_LENGTH = PHONE_PREFIX.length + 10;
    const PHONE_MAX_LENGTH = PHONE_PREFIX.length + 11;

    // Fallback de notify para esta página, caso não esteja carregado do layout
    function notify(msg, type = "info") {
      if (window.toastNotify) return window.toastNotify(msg, type);
      // fallback simples
      if (type === "error") alert("❌ " + msg);
      else if (type === "warning") alert("⚠️ " + msg);
      else alert(msg);
    }

    function toggleRecurrenceEnd() {
      const rec = document.getElementById("recurrence")?.value || "none";
      const field = document.getElementById("recurrenceEndField");
      if (!field) return;
      field.style.display = rec === "none" ? "none" : "block";
    }

    async function salvarTimezone() {
      const sel = document.getElementById("timezoneSelect");
      if (!sel) return;
      const offset = Number(sel.value);
      try {
        const res = await fetch("/user/timezone", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ timezoneOffset: offset })
        });
        const data = await res.json();
        if (!res.ok || data?.ok === false) throw new Error(data?.error || "Erro ao salvar");
        USER_TZ = offset;
        notify("Fuso horário atualizado", "success");
      } catch (err) {
        alert(err?.message || "Erro ao salvar fuso");
      }
    }

    function toUtcFromInput(inputStr, offsetMinutes) {
      // inputStr: "YYYY-MM-DDTHH:MM"
      const [datePart, timePart] = inputStr.split("T");
      const [year, month, day] = datePart.split("-").map(Number);
      const [hour, minute] = timePart.split(":").map(Number);
      const utcMs = Date.UTC(year, month - 1, day, hour, minute);
      return utcMs - offsetMinutes * 60000;
    }

    function fromUtcToInput(utcMs, offsetMinutes) {
      const localMs = utcMs + offsetMinutes * 60000;
      const d = new Date(localMs);
      const pad = (n) => String(n).padStart(2, "0");
      return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())}T${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}`;
    }

    function getTimezoneOffsetSelected() {
      return Number(document.getElementById("timezoneSelect")?.value || USER_TZ || -180);
    }

    function getConfiguredDefaultDdi() {
      const digits = String(document.body?.dataset?.defaultDdi || "55")
        .replace(/\D/g, "")
        .slice(0, 4);

      return digits || "55";
    }

    function normalizeScheduledPhoneDigits(value, options = {}) {
      const digits = String(value || "").replace(/\D/g, "");
      if (!digits) return options.emptyAsPrefix ? PHONE_PREFIX : "";
      if (PHONE_PREFIX.startsWith(digits) && digits.length <= PHONE_PREFIX.length) {
        return PHONE_PREFIX;
      }

      const raw = digits.startsWith(PHONE_PREFIX) ? digits : `${PHONE_PREFIX}${digits}`;
      return raw.slice(0, PHONE_MAX_LENGTH);
    }

    function formatScheduledPhoneDigits(digits) {
      const normalized = normalizeScheduledPhoneDigits(digits, { emptyAsPrefix: true });
      const ddiLength = PHONE_PREFIX.length;
      const countryCode = normalized.slice(0, ddiLength);
      const ddd = normalized.slice(ddiLength, ddiLength + 2);
      const phone = normalized.slice(ddiLength + 2);

      let formatted = countryCode;
      if (ddd) {
        formatted += ` (${ddd}`;
        if (ddd.length === 2) formatted += ")";
      }
      if (phone) {
        formatted += ` ${formatScheduledPhoneLocal(phone)}`;
      }
      return formatted;
    }

    function formatScheduledPhoneLocal(phone) {
      if (phone.length <= 4) return phone;
      if (phone.length <= 8) {
        return `${phone.slice(0, 4)}-${phone.slice(4)}`;
      }
      return `${phone.slice(0, 5)}-${phone.slice(5, 9)}`;
    }

    function formatPhoneDisplay(value) {
      const digits = String(value || "").replace(/\D/g, "");
      if (!digits) return "—";
      if (digits.length > PHONE_MAX_LENGTH && !digits.startsWith(PHONE_PREFIX)) {
        return digits;
      }
      return formatScheduledPhoneDigits(digits);
    }

    function formatPhoneLine(line) {
      const digits = normalizeScheduledPhoneDigits(line, { emptyAsPrefix: false });
      if (!digits) return "";
      return formatScheduledPhoneDigits(digits);
    }

    function normalizeContactsList(list) {
      return Array.isArray(list)
        ? list
            .map((item) => {
              if (!item || typeof item !== "object") return null;
              const number = normalizeScheduledPhoneDigits(item.number || "", { emptyAsPrefix: false });
              if (!number) return null;
              return {
                ...item,
                number,
              };
            })
            .filter(Boolean)
        : [];
    }

    function getTextareaCaretMeta(value, position) {
      const before = String(value || "").slice(0, Number(position || 0));
      const parts = before.split("\n");
      return {
        lineIndex: parts.length - 1,
        digitCount: String(parts[parts.length - 1] || "").replace(/\D/g, "").length,
      };
    }

    function getPositionAfterDigits(line, digitCount) {
      if (!digitCount) return 0;

      let seen = 0;
      for (let i = 0; i < line.length; i++) {
        if (/\d/.test(line[i])) seen++;
        if (seen >= digitCount) return i + 1;
      }
      return line.length;
    }

    function getTextareaCaretPosition(lines, meta) {
      const safeLineIndex = Math.max(0, Math.min(meta.lineIndex, Math.max(lines.length - 1, 0)));
      let absolute = 0;

      for (let i = 0; i < safeLineIndex; i++) {
        absolute += String(lines[i] || "").length + 1;
      }

      return absolute + getPositionAfterDigits(String(lines[safeLineIndex] || ""), meta.digitCount);
    }

    function applyNumsMask() {
      const textarea = document.getElementById("nums");
      if (!textarea) return;

      const rawValue = String(textarea.value || "");
      const startMeta = getTextareaCaretMeta(rawValue, textarea.selectionStart);
      const endMeta = getTextareaCaretMeta(rawValue, textarea.selectionEnd);
      const formattedLines = rawValue.split("\n").map(formatPhoneLine);
      const formattedValue = formattedLines.join("\n");

      if (formattedValue !== rawValue) {
        textarea.value = formattedValue;
      }

      const start = getTextareaCaretPosition(formattedLines, startMeta);
      const end = getTextareaCaretPosition(formattedLines, endMeta);
      textarea.setSelectionRange(start, end);
    }

    function ensureNumsPrefixOnFocus() {
      const textarea = document.getElementById("nums");
      if (!textarea) return;
      if (!textarea.value.trim()) {
        textarea.value = PHONE_PREFIX;
        textarea.setSelectionRange(textarea.value.length, textarea.value.length);
      }
      applyNumsMask();
    }

    function handleNumsKeydown(event) {
      if (event.key !== "Enter") return;
      const textarea = document.getElementById("nums");
      if (!textarea) return;

      event.preventDefault();
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const value = textarea.value;
      const insertion = `\n${PHONE_PREFIX}`;

      textarea.value = `${value.slice(0, start)}${insertion}${value.slice(end)}`;
      const caret = start + insertion.length;
      textarea.setSelectionRange(caret, caret);
      updateNumCount();
      updatePreview();
    }

    function handleNumsInput() {
      applyNumsMask();
      updateNumCount();
      updatePreview();
    }

    // ── Contador de números ────────────────────────────────
    function updateNumCount() {
      const nums = document.getElementById("nums").value
        .split("\n").map(n => n.trim()).filter(Boolean);
      const el = document.getElementById("num-count");
      if (el) {
        const used = contactsData.length ? contactsData.length : nums.length;
        const remaining = Math.max(MAX_NUMBERS - used, 0);
        const pct = used / MAX_NUMBERS;
        let cls = "ok";
        if (used > MAX_NUMBERS) cls = "danger";
        else if (pct >= WARN_THRESHOLD) cls = "warn";
        el.className = `field-hint limit-${cls}`;
        const personalizedTag = contactsData.length ? " • mensagens personalizadas" : "";
        el.innerHTML = `${used} número(s) • limite ${MAX_NUMBERS} • restantes ${remaining}${personalizedTag}`;
      }
    }

    // ── Seleção de arquivo ────────────────────────────────
    function handleFileSelect(input) {
      const file = input.files[0];
      if (!file) return;

      const maxMB = 15;
      if (file.size > maxMB * 1024 * 1024) {
        alert("Arquivo muito grande. Máximo: " + maxMB + "MB");
        input.value = "";
        return;
      }

      const reader = new FileReader();
      reader.onload = (e) => {
        const dataUrl = e.target.result;
        existingFilename = null;

        // Imagem → comprimir via canvas
        if (file.type.startsWith("image/")) {
          const img = new Image();
          img.onload = () => {
            const canvas = document.createElement("canvas");
            const MAX = 1280;
            let w = img.width, h = img.height;
            if (w > MAX || h > MAX) {
              if (w > h) { h = Math.round(h * MAX / w); w = MAX; }
              else       { w = Math.round(w * MAX / h); h = MAX; }
            }
            canvas.width = w; canvas.height = h;
            canvas.getContext("2d").drawImage(img, 0, 0, w, h);
            const compressed = canvas.toDataURL("image/jpeg", 0.85);
            const base64 = compressed.split(",")[1];
            selectedFileData = {
              base64,
              filename: file.name.replace(/\.[^.]+$/, ".jpg"),
              mimetype: "image/jpeg"
            };
            showFilePreview(compressed, null);
            updatePreview();
          };
          img.src = dataUrl;
        } else {
          // Outros arquivos — enviar direto
          const base64 = dataUrl.split(",")[1];
          selectedFileData = { base64, filename: file.name, mimetype: file.type };
          showFilePreview(null, file.name);
          updatePreview();
        }
      };
      reader.readAsDataURL(file);
      input.value = ""; // resetar para permitir re-seleção
    }

    function showFilePreview(imgSrc, docName) {
      const area      = document.getElementById("filePreview");
      const img       = document.getElementById("previewImg");
      const doc       = document.getElementById("previewDoc");
      const docNameEl = document.getElementById("previewDocName");
      const uploadArea = document.getElementById("fileUploadArea");

      area.style.display = "flex";
      uploadArea.style.display = "none";

      if (imgSrc) {
        img.src = imgSrc;
        img.style.display = "block";
        doc.style.display = "none";
      } else {
        img.style.display = "none";
        doc.style.display = "flex";
        docNameEl.textContent = docName;
      }
    }

    function clearFile() {
      selectedFileData = null;
      existingFilename = null;
      document.getElementById("filePreview").style.display = "none";
      document.getElementById("fileUploadArea").style.display = "flex";
      document.getElementById("previewImg").src = "";
      document.getElementById("previewImg").style.display = "none";
      document.getElementById("previewDoc").style.display = "none";
      updatePreview();
    }

    function getPreviewContext() {
      const now = new Date();
      const dataHoje = now.toLocaleDateString("pt-BR");
      const horaAgora = now.toLocaleTimeString("pt-BR", { hour: "2-digit", minute: "2-digit" });

      if (contactsData.length) {
        const first = contactsData[0];
        const vars = first?.vars || {};
        return {
          numero: formatPhoneDisplay(first.number || `${PHONE_PREFIX}999990000`),
          nome: vars.nome || vars.name || "Maria",
          pedido: vars.pedido || vars.order || "#12345",
          data: dataHoje,
          hora: horaAgora,
          ...vars,
        };
      }

      return {
        numero: formatPhoneDisplay(`${PHONE_PREFIX}999990000`),
        nome: "Maria",
        pedido: "#12345",
        data: dataHoje,
        hora: horaAgora,
      };
    }

    function renderTemplatePreview(template) {
      if (!template) return "";
      const ctx = getPreviewContext();
      const mapKeys = {
        numero: ctx.numero,
        number: ctx.numero,
        nome: ctx.nome,
        name: ctx.nome,
        pedido: ctx.pedido,
        order: ctx.pedido,
        data: ctx.data,
        data_atual: ctx.data,
        hoje: ctx.data,
        hora: ctx.hora,
        horario: ctx.hora,
        time: ctx.hora,
        date: ctx.data,
      };

      return template.replace(/{{\s*([\w.-]+)\s*}}/gi, (_m, keyRaw) => {
        const key = String(keyRaw || "").toLowerCase();
        if (mapKeys[key] !== undefined) return mapKeys[key];
        if (ctx[key] !== undefined) return ctx[key];
        return "";
      });
    }

    // ── Prévia estilo WhatsApp ────────────────────────────
    function updatePreview() {
      const msg = document.getElementById("msg").value || "";
      const templated = renderTemplatePreview(msg);
      const previewMessage = document.getElementById("previewMessage");
      const previewImage = document.getElementById("previewImage");
      const previewFile = document.getElementById("previewFile");

      const safe = templated
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\n/g, "<br>");
      previewMessage.innerHTML = safe || "Sua mensagem aparecerá aqui";

      if (selectedFileData) {
        previewFile.style.display = "flex";

        if (selectedFileData.mimetype?.startsWith("image/")) {
          const imgEl = previewImage.querySelector("img");
          imgEl.src = `data:${selectedFileData.mimetype};base64,${selectedFileData.base64}`;
          previewImage.style.display = "block";
        } else {
          previewImage.style.display = "none";
        }
      } else {
        previewFile.style.display = "none";
        previewImage.style.display = "none";
      }
    }

    // ── Importar CSV de números ────────────────────────────
    function importarCSV(input) {
      const file = input.files?.[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = (e) => {
        const text = (e.target?.result || "").toString().replace(/\r/g, "\n");
        const delim = text.includes(";") && text.split(";").length >= text.split(",").length
          ? ";"
          : text.includes("\t")
            ? "\t"
            : ",";

        const lines = text.split("\n").filter(Boolean);
        if (!lines.length) return alert("Nenhum dado encontrado.");

        const headers = lines[0].split(delim).map(h => h.trim().toLowerCase());
        const idxNum = headers.findIndex(h => ["numero","número","number","phone","telefone"].includes(h));
        const idxMsg = headers.findIndex(h => ["mensagem","message","msg","texto"].includes(h));

        let parsed = [];
        if (idxNum >= 0) {
          for (let i = 1; i < lines.length; i++) {
            const cols = lines[i].split(delim);
            const num = normalizeScheduledPhoneDigits(cols[idxNum] || "", { emptyAsPrefix: false });
            if (!num) continue;
            const msg = idxMsg >= 0 ? (cols[idxMsg] || "") : "";

            const vars = {};
            headers.forEach((h, idx) => {
              if (idx === idxNum || idx === idxMsg) return;
              const key = h.replace(/[^a-z0-9_]+/g, "_");
              const val = cols[idx] || "";
              if (key && val) vars[key] = val;
            });

            parsed.push({ number: num, message: msg, vars: Object.keys(vars).length ? vars : undefined });
          }
        }

        // fallback para lista simples
        if (!parsed.length) {
          const tokens = text
            .split(/[\n;,]+/)
            .map(t => t.trim())
            .filter(Boolean);
          parsed = tokens.map(t => ({
              number: normalizeScheduledPhoneDigits(t, { emptyAsPrefix: false }),
              message: ""
            }))
            .filter(p => p.number);
        }

        if (!parsed.length) {
          alert("Nenhum número encontrado no CSV.");
          return;
        }

        contactsData = parsed;
        const textarea = document.getElementById("nums");
        textarea.value = parsed.map(p => formatPhoneDisplay(p.number)).join("\n");
        updateNumCount();
        updatePreview();
      };
      reader.readAsText(file, "utf-8");
      input.value = "";
    }

    // ── Agendar ────────────────────────────────
    async function agendar() {
      clearAllFieldErrors();
      const numbers = document.getElementById("nums").value
        .split("\n")
        .map((n) => normalizeScheduledPhoneDigits(n, { emptyAsPrefix: false }))
        .filter(Boolean);
      const totalCount = contactsData.length ? contactsData.length : numbers.length;

      if (!numbers.length && !contactsData.length) {
        setResult("Informe pelo menos um número", false);
        showFieldError("nums", "Informe pelo menos um número ou importe CSV.");
        return;
      }
      if (totalCount > MAX_NUMBERS) {
        setResult(`Limite do plano: máximo ${MAX_NUMBERS} números`, false);
        showFieldError("nums", `Limite do plano: máximo ${MAX_NUMBERS} números.`);
        return;
      }

      const sendAtVal = document.getElementById("sendAt").value;
      if (!sendAtVal) {
        setResult("Informe a data e hora do envio", false);
        showFieldError("sendAt", "Informe a data e hora do envio.");
        return;
      }

      const tzOffset = getTimezoneOffsetSelected();
      const sendAt = toUtcFromInput(sendAtVal, tzOffset);
      if (sendAt <= Date.now()) {
        setResult("A data deve ser no futuro", false);
        showFieldError("sendAt", "Escolha um horário no futuro.");
        return;
      }

      const recurrence = document.getElementById("recurrence").value || "none";
      const recurrenceEndVal = document.getElementById("recurrenceEnd")?.value || "";
      if (recurrence !== "none" && recurrenceEndVal) {
        const endTs = toUtcFromInput(recurrenceEndVal + "T23:59", tzOffset);
        if (!Number.isFinite(endTs) || endTs <= sendAt) {
          setResult("Encerramento da recorrência deve ser após a primeira data.", false);
          showFieldError("recurrenceEnd", "Encerramento deve ser depois da primeira data.");
          return;
        }
      }

      const message = document.getElementById("msg").value;
      if (!message && !selectedFileData) {
        setResult("Informe uma mensagem ou selecione um arquivo", false);
        showFieldError("msg", "Informe mensagem ou anexe um arquivo.");
        return;
      }

      const payload = {
        numbers,
        contacts: contactsData.length ? normalizeContactsList(contactsData) : undefined,
        message,
        sendAt,
        recurrence: document.getElementById("recurrence").value || "none",
        recurrenceEnd: (document.getElementById("recurrenceEnd")?.value || "")
          ? toUtcFromInput(document.getElementById("recurrenceEnd").value + "T23:59", tzOffset)
          : null,
        file:     selectedFileData ? `data:${selectedFileData.mimetype};base64,${selectedFileData.base64}` : null,
        filename: selectedFileData?.filename || null
      };

      showConfirmModal(payload);
    }

    function editar(id) {
      const row = agRows.find(r => Number(r.id) === Number(id));
      if (!row) return;
      editingId = id;
      existingFilename = row.filename || null;
      selectedFileData = null;

      // Preenche campos
      const nums = JSON.parse(row.numbers || "[]");
      const hasPersonalized = Array.isArray(nums) && nums.length && typeof nums[0] === "object";
      contactsData = hasPersonalized ? normalizeContactsList(nums) : [];
      document.getElementById("nums").value = nums
        .map((n) => formatPhoneDisplay(typeof n === "object" ? n.number : n))
        .join("\n");
      document.getElementById("msg").value = row.message || "";
      const dtStr = fromUtcToInput(row.send_at, getTimezoneOffsetSelected());
      document.getElementById("sendAt").value = dtStr;
      document.getElementById("recurrence").value = row.recurrence || "none";
      if (row.recurrence_end) {
        const endDateStr = fromUtcToInput(Number(row.recurrence_end), getTimezoneOffsetSelected()).slice(0,10);
        document.getElementById("recurrenceEnd").value = endDateStr;
      } else {
        document.getElementById("recurrenceEnd").value = "";
      }
      toggleRecurrenceEnd();

      // Preview do arquivo existente (apenas nome)
      if (row.filename) {
        document.getElementById("filePreview").style.display = "flex";
        document.getElementById("fileUploadArea").style.display = "none";
        document.getElementById("previewImg").style.display = "none";
        const doc = document.getElementById("previewDoc");
        doc.style.display = "flex";
        document.getElementById("previewDocName").textContent = row.filename;
        selectedFileData = null; // mantém arquivo atual a menos que reenvie
      } else {
        clearFile();
      }

      // UI
      setResult("Editando agendamento pendente #" + id, true);
      document.getElementById("btnAgendar").innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Salvar alterações';

      updateNumCount();
      updatePreview();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function duplicar(id) {
      const row = agRows.find(r => Number(r.id) === Number(id));
      if (!row) return;
      editingId = null; // novo
      existingFilename = row.filename || null;
      selectedFileData = null;

      // Números
      try {
        const nums = JSON.parse(row.numbers || "[]");
        const hasPersonalized = Array.isArray(nums) && nums.length && typeof nums[0] === "object";
        contactsData = hasPersonalized ? normalizeContactsList(nums) : [];
        document.getElementById("nums").value = nums
          .map((n) => formatPhoneDisplay(typeof n === "object" ? n.number : n))
          .join("\n");
      } catch {
        contactsData = [];
        document.getElementById("nums").value = "";
      }

      // Mensagem
      document.getElementById("msg").value = row.message || "";

      // Recorrência
      document.getElementById("recurrence").value = row.recurrence || "none";
      if (row.recurrence_end) {
        const endDate = new Date(Number(row.recurrence_end));
        document.getElementById("recurrenceEnd").value = endDate.toISOString().slice(0,10);
      } else {
        document.getElementById("recurrenceEnd").value = "";
      }
      toggleRecurrenceEnd();

      // Data/hora: limpa para forçar escolha nova
      document.getElementById("sendAt").value = "";

      // Preview de arquivo (mantém nome se existir)
      if (row.filename) {
        document.getElementById("filePreview").style.display = "flex";
        document.getElementById("fileUploadArea").style.display = "none";
        document.getElementById("previewImg").style.display = "none";
        const doc = document.getElementById("previewDoc");
        doc.style.display = "flex";
        document.getElementById("previewDocName").textContent = row.filename;
      } else {
        clearFile();
      }

      setResult(`Duplicando agendamento #${id}. Ajuste data/hora e salve.`, true);
      document.getElementById("btnAgendar").innerHTML = '<i class="fa-solid fa-calendar-plus"></i> Criar agendamento';

      updateNumCount();
      updatePreview();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function showConfirmModal(payload) {
      const modal = document.getElementById("confirmModal");
      document.getElementById("summary-datetime").textContent = formatDateTime(payload.sendAt);
      const qty = contactsData.length ? contactsData.length : payload.numbers.length;
      document.getElementById("summary-qty").textContent = `${qty} número(s)`;
      document.getElementById("summary-recurrence").textContent = (payload.recurrence || "none").toUpperCase();
      document.getElementById("summary-message").textContent = payload.message ? truncate(payload.message, 120) : "—";
      const fileLabel = payload.filename
        || (payload.file ? "Arquivo novo" : null)
        || (existingFilename ? `Mantém: ${existingFilename}` : "Nenhum");
      document.getElementById("summary-file").textContent = fileLabel;
      const hasPersonalized = contactsData.length > 0;
      const personalizedLine = document.getElementById("summary-personalized");
      if (personalizedLine) {
        personalizedLine.textContent = hasPersonalized ? "Sim (mensagem por contato)" : "Não";
      }

      modal.classList.remove("hidden");

      const confirmBtn = document.getElementById("btnConfirmModal");
      const cancelBtn = document.getElementById("btnCancelModal");
      confirmBtn.innerHTML = editingId
        ? '<i class="fa-solid fa-floppy-disk"></i> Salvar alterações'
        : '<i class="fa-solid fa-check"></i> Confirmar e agendar';

      const onConfirm = () => {
        modal.classList.add("hidden");
        confirmBtn.removeEventListener("click", onConfirm);
        cancelBtn.removeEventListener("click", onCancel);
        submitAgendamento(payload);
      };
      const onCancel = () => {
        modal.classList.add("hidden");
        confirmBtn.removeEventListener("click", onConfirm);
        cancelBtn.removeEventListener("click", onCancel);
      };

      confirmBtn.addEventListener("click", onConfirm);
      cancelBtn.addEventListener("click", onCancel);
    }

    function truncate(text, max) {
      if (!text) return "";
      return text.length > max ? text.slice(0, max) + "…" : text;
    }

    function formatDateTime(ts) {
      const d = new Date(ts + getTimezoneOffsetSelected() * 60000);
      const pad = (n) => String(n).padStart(2, "0");
      return `${pad(d.getUTCDate())}/${pad(d.getUTCMonth() + 1)}/${d.getUTCFullYear()} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}`;
    }

    async function submitAgendamento(payload) {
      const btnEl = document.getElementById("btnAgendar");
      btnEl.disabled = true;
      btnEl.innerHTML = editingId
        ? '<i class="fa-solid fa-spinner fa-spin"></i> Salvando...'
        : '<i class="fa-solid fa-spinner fa-spin"></i> Agendando...';

      // manter arquivo atual se não enviar um novo
      if (editingId && !selectedFileData && existingFilename) {
        payload.keepExistingFile = true;
        payload.file = null;
        payload.filename = null;
      }
      const url = editingId
        ? `/api/agendamentos/update/${editingId}`
        : "/api/agendamentos/create";
      const method = editingId ? "PUT" : "POST";

      try {
        const res = await fetch(url, {
          method,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const data = await res.json();
        const warnings = Array.isArray(data?.warnings)
          ? data.warnings.filter((warning) => typeof warning === "string" && warning.trim())
          : [];
        const skippedCount = Array.isArray(data?.skipped)
          ? data.skipped.length
          : Number(data?.skipped || 0);

        if (data.ok) {
          setResult(editingId ? "✅ Agendamento atualizado!" : "✅ Agendamento criado com sucesso!", true);
          warnings.forEach((warning) => notify(warning, "warning"));
          if (skippedCount > 0) {
            notify(`${skippedCount} contato(s) foram removidos pelas regras de seguranca.`, "warning");
          }
          // Limpar formulário
          document.getElementById("nums").value = "";
          document.getElementById("msg").value = "";
          document.getElementById("sendAt").value = "";
          document.getElementById("recurrence").value = "none";
          document.getElementById("recurrenceEnd").value = "";
          clearFile();
          contactsData = [];
          updateNumCount();
          updatePreview();
          carregarAgendamentos();
          editingId = null;
          existingFilename = null;
          btnEl.innerHTML = '<i class="fa-solid fa-calendar-plus"></i> Agendar Mensagem';
        } else {
          warnings.forEach((warning) => notify(warning, "warning"));
          if (skippedCount > 0) {
            notify(`${skippedCount} contato(s) foram removidos pelas regras de seguranca.`, "warning");
          }
          setResult("❌ " + (data.error || "Erro ao agendar"), false);
          btnEl.innerHTML = '<i class="fa-solid fa-calendar-plus"></i> Agendar Mensagem';
        }
      } catch {
        setResult("❌ Erro de conexão", false);
        btnEl.innerHTML = '<i class="fa-solid fa-calendar-plus"></i> Agendar Mensagem';
      } finally {
        btnEl.disabled = false;
      }
    }

    function setResult(msg, ok) {
      const el = document.getElementById("result");
      el.textContent = msg;
      el.style.color = ok ? "#2ee6a6" : "#e54848";
    }

    // ── Excluir ────────────────────────────────────────────────────
    async function excluir(id) {
      if (!confirm("Excluir este agendamento?")) return;
      await fetch(`/api/agendamentos/delete/${id}`, { method: "DELETE" });
      carregarAgendamentos();
    }

    // ── Listar ─────────────────────────────────────────────────────
    async function carregarAgendamentos() {
      const tabela = document.getElementById("agendamentosTable");
      tabela.innerHTML = `<tr><td colspan="6" class="loading">Carregando...</td></tr>`;

      try {
        const status = document.getElementById("statusFilter")?.value || "all";
        const term = (document.getElementById("searchTerm")?.value || "").trim();
        const pageSize = Number(document.getElementById("pageSize")?.value || 10);
        const orderRaw = document.getElementById("orderBy")?.value || "send_at|desc";
        const [orderBy, orderDir] = orderRaw.split("|");
        const fromStr = document.getElementById("dateFrom")?.value;
        const toStr = document.getElementById("dateTo")?.value;
        const fromTs = fromStr ? new Date(fromStr + "T00:00:00").getTime() : "";
        const toTs = toStr ? new Date(toStr + "T23:59:59").getTime() : "";

        const qs = new URLSearchParams({
          status,
          term,
          page: String(agPage),
          pageSize: String(pageSize),
          orderBy,
          orderDir,
        });
        if (fromTs) qs.set("from", String(fromTs));
        if (toTs) qs.set("to", String(toTs));

        const res = await fetch(`/api/agendamentos/list?${qs.toString()}`);
        const payload = await res.json();
        const rows = Array.isArray(payload.rows) ? payload.rows : [];
        agPage = Number(payload.page) || 1;
        agTotalPages = Number(payload.totalPages) || 1;
        updatePaginationUI();

        agRows = rows;

        if (!rows.length) {
          tabela.innerHTML = `<tr><td colspan="6" class="loading">Nenhum agendamento encontrado</td></tr>`;
          return;
        }

        tabela.innerHTML = "";

        rows.forEach(row => {
          const nums = JSON.parse(row.numbers || "[]");
          const hasPersonalized = Array.isArray(nums) && nums.length && typeof nums[0] === "object";
          const numsDisplay = hasPersonalized
            ? nums.map((c) => `${formatPhoneDisplay(c.number || "")} <span class="pill-personalized">msg personalizada</span>`).join("<br>")
            : nums.map((n) => formatPhoneDisplay(n)).join("<br>");
          const recurrenceHtml = recurrenceBadge(row.recurrence);
          const isPending = row.status === "pending";
          const actionButtons = isPending
            ? `<button class="btn-edit" onclick="editar(${row.id})">
                 <i class="fa-solid fa-pen"></i> Editar
               </button>
               <button class="btn-secondary" onclick="duplicar(${row.id})">
                 <i class="fa-solid fa-copy"></i> Duplicar
               </button>
               <button class="btn-del" onclick="excluir(${row.id})">
                 <i class="fa-solid fa-trash"></i>
                 Excluir
               </button>`
            : `<button class="btn-secondary" onclick="verDetalhes(${row.id})">
                 <i class="fa-solid fa-list"></i>
                 Detalhes
               </button>
               <button class="btn-del" onclick="excluir(${row.id})">
                 <i class="fa-solid fa-trash"></i>
                 Excluir
               </button>`;
          const tr = document.createElement("tr");
          tr.innerHTML = `
            <td>${numsDisplay}</td>
            <td>${row.message || "<i>(arquivo)</i>"}</td>
            <td>
              ${formatarData(row.send_at)}
              ${recurrenceHtml}
            </td>
            <td>
              <span class="countdown" data-send="${row.send_at}" data-status="${row.status}">
                ${isPending ? formatarCountdown(row.send_at) : "-"}
              </span>
            </td>
            <td class="status ${row.status}">
              ${formatStatusLabel(row.status)}
            </td>
            <td class="action-cell">
              ${actionButtons}
            </td>
          `;
          tabela.appendChild(tr);
        });

        iniciarCountdowns();

      } catch {
        tabela.innerHTML = `<tr><td colspan="6" class="error">Erro ao carregar</td></tr>`;
      }
    }

    function resetPageAndLoad() {
      agPage = 1;
      carregarAgendamentos();
    }

    function changePage(delta) {
      const next = Math.min(Math.max(1, agPage + delta), agTotalPages);
      if (next === agPage) return;
      agPage = next;
      carregarAgendamentos();
    }

    function updatePaginationUI() {
      const info = document.getElementById("pageInfo");
      if (info) info.textContent = `Página ${agPage}/${agTotalPages}`;
      const prev = document.getElementById("prevPage");
      const next = document.getElementById("nextPage");
      if (prev) prev.disabled = agPage <= 1;
      if (next) next.disabled = agPage >= agTotalPages;
    }

    function formatarData(ts) {
      const offset = getTimezoneOffsetSelected();
      const d = new Date(ts + offset * 60000);
      const pad = (n) => String(n).padStart(2, "0");
      return `${pad(d.getUTCDate())}/${pad(d.getUTCMonth()+1)}/${d.getUTCFullYear()} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}`;
    }

    function formatarCountdown(ts) {
      const diff = ts - Date.now();
      if (diff <= 0) return "agora";
      const sec = Math.floor(diff / 1000);
      const mins = Math.floor(sec / 60);
      const hrs = Math.floor(mins / 60);
      const days = Math.floor(hrs / 24);
      const rHrs = hrs % 24;
      const rMins = mins % 60;

      if (days > 0) return `em ${days}d ${rHrs}h`;
      if (hrs > 0) return `em ${hrs}h ${rMins}m`;
      const rSecs = sec % 60;
      if (mins > 0) return `em ${mins}m ${rSecs}s`;
      return `em ${rSecs}s`;
    }

    let countdownTimer = null;

    function iniciarCountdowns() {
      if (countdownTimer) clearInterval(countdownTimer);
      const update = () => {
        document.querySelectorAll(".countdown").forEach(el => {
          const status = el.dataset.status;
          if (status !== "pending") {
            el.textContent = "-";
            return;
          }
          const ts = Number(el.dataset.send || 0);
          el.textContent = formatarCountdown(ts);
        });
      };
      update();
      countdownTimer = setInterval(update, 1000);
    }

    function formatarRecorrencia(rec) {
      switch (rec) {
        case "daily": return "Diário";
        case "weekly": return "Semanal";
        case "monthly": return "Mensal";
        default: return "Único";
      }
    }

    function recurrenceBadge(rec) {
      if (!rec || rec === "none") return "";
      return `<div class="recurrence-pill">
        <i class="fa-solid fa-rotate"></i> ${formatarRecorrencia(rec)}
      </div>`;
    }

    function formatStatusLabel(status) {
      switch (status) {
        case "pending":
          return "⏳ Pendente";
        case "failed":
          return "❌ Falhou";
        default:
          return "✅ Enviado";
      }
    }

    async function verDetalhes(id) {
      const modal = document.getElementById("detailsModal");
      const body = document.getElementById("detailsBody");
      if (!modal || !body) return;

      body.innerHTML = "Carregando...";
      modal.classList.remove("hidden");

      try {
        const res = await fetch(`/api/agendamentos/log/${id}`);
        if (!res.ok) throw new Error("Falha ao buscar detalhes");
        const payload = await res.json();
        const log = payload?.log;
        const items = Array.isArray(payload?.items) ? payload.items : [];

        if (!log) {
          body.innerHTML = "<p>Nenhum log encontrado.</p>";
          return;
        }

        const sentAt = new Date(Number(log.sent_at || 0)).toLocaleString("pt-BR");
        const success = log.success_count ?? 0;
        const failure = log.failure_count ?? 0;
        const rows = items.map((it) => {
          const status = it.status === "sent" ? "✅" : "⚠️";
          const when = new Date(Number(it.sent_at || 0)).toLocaleString("pt-BR");
          const err = it.error ? `<div class=\"item-error\">${it.error}</div>` : "";
          return `<div class=\"item-row\"><div>${status} ${formatPhoneDisplay(it.number)}</div><div class=\"item-date\">${when}</div>${err}</div>`;
        }).join("") || "<p>Sem itens detalhados.</p>";

        body.innerHTML = `
          <div class="details-head">
            <div><strong>Processado em:</strong> ${sentAt}</div>
            <div><strong>Sucesso:</strong> ${success}</div>
            <div><strong>Falhas:</strong> ${failure}</div>
          </div>
          <div class="details-items">${rows}</div>
        `;
      } catch (err) {
        body.innerHTML = `<p>Erro ao carregar detalhes.</p>`;
      }
    }

    function fecharDetalhes() {
      const modal = document.getElementById("detailsModal");
      if (modal) modal.classList.add("hidden");
    }

    updateNumCount();
    updatePreview();
    const numsEl = document.getElementById("nums");
    numsEl?.addEventListener("focus", ensureNumsPrefixOnFocus);
    numsEl?.addEventListener("keydown", handleNumsKeydown);
    const tzSel = document.getElementById("timezoneSelect");
    if (tzSel) tzSel.value = String(USER_TZ);
    toggleRecurrenceEnd();
    carregarAgendamentos();
    setInterval(carregarAgendamentos, 10000);
  </script>

</body>

</html>
