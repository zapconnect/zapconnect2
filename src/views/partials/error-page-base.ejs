<style>
  :root{
    --bg:#0D1222;--card:#161B30;--border:#373E59;--text:#FFFFFF;--muted:#AAB0D9;
    --primary:#6C64EF;--primary-hover:#8B5CF6;--danger:#ef4444;--warning:#f2c94c;--success:#22C55E;
  }
  *{box-sizing:border-box;font-family:Inter,system-ui,sans-serif;}
  body{margin:0;min-height:100vh;background:radial-gradient(circle at top,#151a3a,var(--bg));color:var(--text);display:flex;align-items:center;justify-content:center;padding:16px;}
  .card{
    width:100%;max-width:440px;background:linear-gradient(180deg,#181f3d,#12172e);
    border:1px solid var(--border);border-radius:18px;padding:32px;text-align:center;
    box-shadow:0 20px 60px rgba(108,100,239,.35);
  }
  .icon{
    width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;
    margin:0 auto 14px;font-size:26px;
  }
  .icon.danger{background:rgba(239,68,68,0.12);color:var(--danger);}
  .icon.warning{background:rgba(242,201,76,0.15);color:var(--warning);}
  .icon.success{background:rgba(34,197,94,0.12);color:var(--success);}
  h1{margin:0;font-size:22px;}
  p{color:var(--muted);font-size:14px;line-height:1.6;margin:10px 0 16px;}
  .btn{
    width:100%;padding:14px;border-radius:14px;border:none;cursor:pointer;
    background:linear-gradient(135deg,var(--primary),var(--primary-hover));color:#fff;
    font-weight:700;display:inline-flex;align-items:center;justify-content:center;gap:8px;
    box-shadow:0 0 30px rgba(108,100,239,.45);text-decoration:none;transition:.2s;
  }
  .btn:hover{filter:brightness(1.12);}
  .link{display:block;margin-top:12px;font-size:13px;color:var(--primary);text-decoration:none;}
  .link:hover{text-decoration:underline;}
</style>
