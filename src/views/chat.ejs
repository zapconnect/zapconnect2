<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <title>Chats • ZapConnect</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/img/favinco.png" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/chats.css" />

  <!-- ✅ Variáveis definidas ANTES do chat.js carregar -->
  <script>
    window.USER_ID = "<%= user.id %>";
    window.SESSION_NAME = "<%= typeof sessionName !== 'undefined' ? sessionName : '' %>";
  </script>
</head>

<body>
  <div class="wrap">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <h1>WhatsApp • Painel</h1>
        <a href="/painel" class="btn-voltar">← Voltar</a>
      </div>

      <div class="search">
        <input id="searchBox" placeholder="Pesquisar ou começar uma nova conversa" autocomplete="off" />
      </div>

      <div id="chatlist" class="chatlist"></div>
    </aside>

    <!-- CHAT -->
    <section class="chat">

      <!-- ALERTA MODO HUMANO ATIVO -->
      <div id="humanAlert" style="display:none;">
        <i class="fa-solid fa-user-gear"></i> Atendimento humano ativo — o bot está pausado
        <br>
        <span id="humanTimer"></span>
      </div>

      <header class="chat-header">
        <div class="chat-title">
          <button id="btnToggleSidebar" class="btn-menu" title="Conversas">☰</button>
          <h2 id="chatTitle">Selecione um chat…</h2>
          <span id="tagHuman" class="tag-human" style="display:none;">HUMANO</span>
          <span id="tagAiOff" class="tag-ai-off" style="display:none;">IA DESLIGADA</span>
        </div>

        <div class="header-actions" id="humanButtons" style="display:none;">
          <span id="pipelineStatus" class="pipeline-status"></span>

          <div class="human-on-group">
            <button id="btnHumanOn"><i class="fa-solid fa-user-check"></i> Atender</button>
            <select id="humanDuration" class="human-duration-select" title="Duração do atendimento">
              <option value="300000">5 min</option>
              <option value="900000">15 min</option>
              <option value="1800000">30 min</option>
              <option value="null">Sem limite</option>
            </select>
          </div>
          <button id="btnHumanOff" disabled><i class="fa-solid fa-robot"></i> Voltar para bot</button>
          <button id="btnAiToggle" style="display:none;"><i class="fa-solid fa-robot"></i> IA ligada</button>
          <button id="btnClearAi" title="Limpar histórico da IA" style="display:none;"><i class="fa-solid fa-broom"></i> Resetar IA</button>
        </div>

        <button id="btnNotesToggle" class="btn-notes-toggle" title="Mostrar/ocultar notas">
          <i class="fa-solid fa-note-sticky"></i>
          <span class="btn-notes-text">Notas</span>
          <i class="fa-solid fa-chevron-down" id="btnNotesChevron"></i>
        </button>
        <button id="btnSearch" class="btn-search-toggle" title="Buscar na conversa"><i class="fa-solid fa-magnifying-glass"></i></button>
      </header>

      <!-- Barra de busca -->
      <div id="searchBar" class="search-bar" style="display:none;">
        <div class="search-bar-inner">
          <input id="searchInput" class="search-bar-input" placeholder="Buscar na conversa..." autocomplete="off" />
          <span id="searchCount" class="search-count"></span>
          <button id="searchPrev" class="search-nav" title="Anterior">↑</button>
          <button id="searchNext" class="search-nav" title="Próximo">↓</button>
          <button id="searchClose" class="search-close" title="Fechar">✕</button>
        </div>
      </div>

      <!-- Notas internas (não enviadas ao cliente) -->
      <div id="notesPanel" class="notes-panel hidden">
        <div class="notes-head">
          <div class="notes-head-titles">
            <span class="notes-title">Notas internas</span>
            <span id="notesCount" class="notes-count">0</span>
          </div>
          <button id="notesRefresh" class="notes-refresh" title="Recarregar notas">Atualizar</button>
        </div>
        <div id="notesList" class="notes-list empty">Nenhuma nota interna ainda.</div>
        <form id="noteForm" class="notes-form">
          <textarea id="noteInput" class="notes-input" placeholder="Adicionar nota interna (aparece só no painel)"></textarea>
          <div class="notes-actions">
            <span class="note-helper">Use para combinar transferências ou registrar detalhes sensíveis. Não vai para o cliente.</span>
            <button type="submit" id="noteSubmit" class="notes-submit">Salvar nota</button>
          </div>
        </form>
      </div>

      <main id="messages" class="messages"></main>

      <!-- Preview do arquivo selecionado -->
      <div id="filePreview" class="file-preview" style="display:none;">
        <div class="file-preview-inner">
          <img id="filePreviewImg" src="" alt="" style="display:none;" />
          <div id="filePreviewDoc" class="file-preview-doc" style="display:none;">
        <span class="file-preview-icon"><i class="fa-solid fa-file-lines"></i></span>
            <span id="filePreviewName"></span>
          </div>
          <button id="fileClear" class="file-clear" title="Remover arquivo">✕</button>
        </div>
      </div>

      <footer class="chat-footer">
        <div class="input-wrapper">
          <button class="btn-emoji" title="Emojis"><i class="fa-regular fa-face-smile"></i></button>

          <!-- Input de arquivo oculto -->
          <input type="file" id="fileInput" accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.zip,.txt" style="display:none;" />
          <button class="btn-attach" id="btnAttach" title="Anexar arquivo"><i class="fa-solid fa-paperclip"></i></button>

          <textarea id="inputMsg" class="inputMsg" placeholder="Digite uma mensagem" rows="1"></textarea>
          <button id="btnSend" class="btn-send">➤</button>
        </div>
      </footer>

    </section>
  </div>
  <div id="sidebarOverlay" class="sidebar-overlay"></div>

  <!-- MODAL DE EMOJIS -->
  <div id="emojiModal" class="emoji-modal">
      <div class="emoji-modal-content">
        <div class="emoji-header">
          <span><i class="fa-regular fa-face-smile"></i> Emojis</span>
          <button id="closeEmoji" class="close-emoji"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="emoji-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input id="emojiSearch" type="text" placeholder="Pesquisar emoji" autocomplete="off">
        </div>
        <div class="emoji-tabs" id="emojiTabs"></div>
        <div class="emoji-scroll" id="emojiScroll"></div>
      </div>
    </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/loading-utils.js"></script>
  <script src="/js/chat.js"></script>
</body>

</html>
