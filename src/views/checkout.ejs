<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <title>Checkout • ZapConnect</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="icon" href="/img/favinco.png" />
  <link rel="stylesheet" href="/css/checkout.css" />
</head>

<body>

  <!-- HEADER -->
  <header class="topbar">
    <div class="brand">
      <i class="fa-solid fa-credit-card"></i>
      <h1>Escolha seu plano</h1>
    </div>

    <a href="/user" class="back-link">
      <i class="fa-solid fa-arrow-left"></i> Voltar
    </a>
  </header>

  <!-- ALERTA -->
  <div id="alert-container"></div>

  <!-- PLANOS -->
  <main class="plans">
    <% 
      const planMeta = {
        free: { icon: "fa-gift", buttonIcon: "fa-lock", cta: "Ativado automaticamente" },
        starter: { icon: "fa-rocket", buttonIcon: "fa-credit-card", cta: "Assinar agora" },
        pro: { icon: "fa-crown", buttonIcon: "fa-bolt", cta: "Assinar Pro" }
      };
      const planList = Array.isArray(plans) ? plans : [];
    %>

    <% planList.forEach(plan => { 
      const meta = planMeta[plan.name] || { icon: "fa-box", buttonIcon: "fa-credit-card", cta: `Assinar ${plan.displayName}` };
      const isFree = plan.name === "free" || Number(plan.price || 0) === 0;
      const badgeClass = plan.name === "pro" ? "pro" : (plan.highlight ? "primary" : "");
      const formattedPrice = Number(plan.price || 0).toLocaleString("pt-BR", {
        minimumFractionDigits: Number(plan.price || 0) % 1 === 0 ? 0 : 2,
        maximumFractionDigits: 2
      });
    %>
      <div class="plan <%= plan.highlight ? 'highlight' : '' %> <%= plan.name === 'free' ? 'free' : '' %>">
        <span class="badge <%= badgeClass %>"><%= plan.badgeLabel || plan.displayName %></span>

        <h3>
          <i class="fa-solid <%= meta.icon %>"></i>
          <%= plan.displayName %>
        </h3>

        <div class="price">R$ <%= formattedPrice %><% if (!isFree) { %><span>/mês</span><% } %></div>

        <ul class="features">
          <% (plan.featureList || []).forEach(feature => { %>
            <li><i class="fa-solid fa-check"></i> <%= feature %></li>
          <% }) %>
        </ul>

        <% if (isFree) { %>
          <button class="btn" disabled>
            <i class="fa-solid <%= meta.buttonIcon %>"></i>
            <%= meta.cta %>
          </button>
        <% } else { %>
          <button class="btn btn-primary" onclick="assinar('<%= plan.name %>', this)">
            <i class="fa-solid <%= meta.buttonIcon %>"></i>
            <%= meta.cta %>
          </button>
        <% } %>
      </div>
    <% }) %>

  </main>

  <!-- SCRIPT (inalterado) -->
  <script>
    const params = new URLSearchParams(window.location.search);
    const alertContainer = document.getElementById("alert-container");

    const messages = {
      expired: "⚠️ Seu plano expirou. Assine para continuar.",
      cancelled: "❌ Assinatura cancelada. Assine novamente.",
      past_due: "⚠️ Pagamento pendente. Atualize seu cartão."
    };

    const status = params.get("status");

    if (params.get("expired") === "1" || messages[status]) {
      alertContainer.innerHTML = `
        <div class="alert">
          <span>${messages[status] || messages.expired}</span>
          <button onclick="this.parentElement.remove()">×</button>
        </div>
      `;
    }

    async function assinar(plan, btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Redirecionando...';

      try {
        const res = await fetch("/subscription/create", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ plan })
        });

        const data = await res.json();
        if (!data.url) throw new Error();

        window.location.href = data.url;
      } catch {
        alert("Erro ao iniciar pagamento");
        btn.disabled = false;
        btn.innerText = "Assinar plano";
      }
    }
  </script>

</body>

</html>
