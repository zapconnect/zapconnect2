<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <title>Painel • ZapConnect</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="icon" href="/img/favinco.png" />

  <!-- Boxicons -->
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">

  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/painel.css">

  <script src="/socket.io/socket.io.js"></script>
</head>

<body>

  <!-- ============================
🔝 HEADER
============================= -->
  <header class="topbar">
    <div class="brand">
      <img src="/img/logo3.png" alt="ZapConnect" class="brand-logo">
    </div>

    <div class="top-actions">
      <div id="status-indicator" class="status-indicator">
        <span id="status-dot" class="status-dot status-offline"></span>
        <span id="status-text">Offline</span>
      </div>

      <button class="btn-danger small" onclick="logout()">
        <i class="fa-solid fa-right-from-bracket"></i>
        Sair
      </button>
    </div>
  </header>

  <!-- ============================
📦 CONTEÚDO
============================= -->
  <main class="container">

    <!-- ============================
    📊 MÉTRICAS
    ============================= -->
    <div class="stats-grid">

      <div class="stat-card">
        <div class="stat-icon" style="background:rgba(46,230,166,.15);color:#2ee6a6">
          <i class="fa-brands fa-whatsapp"></i>
        </div>
        <div class="stat-body">
          <div class="stat-value" id="stat-sessions">—</div>
          <div class="stat-label">Sessões ativas</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background:rgba(90,200,250,.15);color:#5ac8fa">
          <i class="fa-solid fa-address-book"></i>
        </div>
        <div class="stat-body">
          <div class="stat-value" id="stat-clientes">—</div>
          <div class="stat-label">Clientes no CRM</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background:rgba(242,201,76,.15);color:#f2c94c">
          <i class="fa-solid fa-clock"></i>
        </div>
        <div class="stat-body">
          <div class="stat-value" id="stat-agendamentos">—</div>
          <div class="stat-label">Agendamentos pendentes</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background:rgba(108,100,239,.15);color:#a89ef5">
          <i class="fa-solid fa-robot"></i>
        </div>
        <div class="stat-body">
          <div class="stat-value" id="stat-ia">—</div>
          <div class="stat-label">Mensagens IA no mês</div>
        </div>
      </div>

    </div>

    <div class="grid">

      <!-- 👤 Usuário -->
      <section class="card">
        <h2><i class="fa-solid fa-user"></i> Usuário</h2>

        <p><b>ID:</b> <span id="user-id"></span></p>
        <p><b>Nome:</b> <span id="user-name"></span></p>

        <label class="label">Prompt da IA</label>
        <textarea id="user-prompt" class="textarea"
          placeholder="Defina como a IA deve responder aos clientes..."
          oninput="updateCharCount()"></textarea>

        <div class="prompt-meta">
          <span id="prompt-count" class="prompt-count">0 caracteres</span>
          <span id="prompt-hint" class="prompt-hint"></span>
        </div>

        <button class="btn btn-primary full" onclick="updatePrompt()">
          <i class="fa-solid fa-floppy-disk"></i>
          Salvar Prompt
        </button>
      </section>

      <!-- ⚡ Atalhos -->
      <section class="card shortcuts-card">
        <h2><i class="fa-solid fa-bolt"></i> Atalhos Rápidos</h2>

        <div class="shortcut-grid">
          <button class="shortcut purple" onclick="goToChat()">
            <i class="fa-solid fa-comments"></i>
            Chats
          </button>

          <button class="shortcut pink" onclick="goToDisparo()">
            <i class="fa-solid fa-bullhorn"></i>
            Disparo
          </button>

          <button class="shortcut red" onclick="goToAgendamentos()">
            <i class="fa-solid fa-clock"></i>
            Agendar
          </button>

          <button class="shortcut violet" onclick="window.location.href='/crm'">
            <i class="fa-solid fa-address-book"></i>
            CRM
          </button>

          <button class="shortcut teal" onclick="window.location.href='/fallback-settings'">
            <i class="fa-solid fa-person-circle-question"></i>
            Fallback
          </button>

          <button class="shortcut green" onclick="goToSessions()">
            <i class="fa-solid fa-mobile-screen-button"></i>
            Sessões
          </button>

          <button class="shortcut blue" onclick="window.location.href='/user'">
            <i class="fa-solid fa-user-gear"></i>
            Conta
          </button>
        </div>
      </section>

      <!-- 🤖 IA -->
      <section class="card">
        <h2><i class="fa-solid fa-robot"></i> IA Automática</h2>

        <label class="switch">
          <input type="checkbox" id="ia-toggle" <%=user.ia_enabled ? 'checked' : '' %>
          onchange="toggleIA()"
          >
          <span class="slider"></span>
        </label>

        <p class="muted">
          Status:
          <b id="ia-status">
            <%= user.ia_enabled ? 'Ativada' : 'Desativada' %>
          </b>
        </p>

        <!-- 🌙 Horário de silêncio -->
        <div class="silence-wrap">
          <div class="silence-header">
            <span class="ia-usage-label">🌙 Horário de silêncio</span>
            <label class="switch switch-sm">
              <input type="checkbox" id="silence-toggle" onchange="toggleSilence()">
              <span class="slider"></span>
            </label>
          </div>

          <div id="silence-config" class="silence-config" style="display:none;">
            <div class="silence-row">
              <label>Das</label>
              <select id="silence-start" class="silence-select">
                <% for(let h=0; h<24; h++) { %>
                  <option value="<%= h %>"><%= String(h).padStart(2,'0') %>:00</option>
                <% } %>
              </select>
              <label>até</label>
              <select id="silence-end" class="silence-select">
                <% for(let h=0; h<24; h++) { %>
                  <option value="<%= h %>"><%= String(h).padStart(2,'0') %>:00</option>
                <% } %>
              </select>
              <button class="btn btn-accent btn-sm" onclick="saveSilence()">Salvar</button>
            </div>
            <p class="silence-hint">A IA não responderá automaticamente neste intervalo.</p>
          </div>
        </div>

        <div class="ia-usage-wrap" id="ia-usage-wrap" style="display:none;">
          <div class="ia-usage-header">
            <span class="ia-usage-label">Mensagens IA este mês</span>
            <span class="ia-usage-count" id="ia-usage-count">—</span>
          </div>
          <div class="ia-progress-track">
            <div class="ia-progress-bar" id="ia-progress-bar"></div>
          </div>
          <div class="ia-usage-footer">
            <span id="ia-usage-remaining"></span>
          </div>
        </div>
      </section>

      <!-- 📱 Criar Sessão -->
      <!-- 📱 Criar Sessão -->
      <section class="card">
        <h2><i class="fa-solid fa-plus"></i> Criar Sessão de whatsapp</h2>

        <input id="session-name" class="textarea" placeholder="Ex: celular1">

        <button class="btn btn-accent full" onclick="createSession()">
          <i class="fa-solid fa-circle-check"></i>
          Criar Sessão
        </button>

        <!-- QR AREA -->
        <div id="qr-preview" class="qr-area">

          <!-- 🔄 LOADING -->
          <div id="qr-loading" class="qr-loading" style="display: none;">
            <i class="fa-solid fa-qrcode"></i>
            <p>Gerando QR Code…</p>
          </div>

          <!-- ⏳ PLACEHOLDER -->
          <div id="qr-placeholder" class="qr-placeholder">
            <div class="qr-shimmer"></div>
            <div class="qr-lines">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>

          <!-- 📸 QR -->
          <img id="qr-img" class="qr-img" style="display:none;">

          <!-- 🔁 REFRESH -->
          <button id="qr-refresh" class="btn small btn-accent" style="display:none;" onclick="refreshQR()">
            <i class="fa-solid fa-rotate"></i>
            Atualizar QR
          </button>

          <!-- ⏱️ TIMER -->
          <p id="qr-timer" class="qr-info"></p>
        </div>
      </section>


    </div>
    <div id="connect-alert" class="alert-connect hidden">
      <i class="fa-solid fa-triangle-exclamation"></i>
      Nenhum WhatsApp conectado.
      Crie uma sessão e escaneie o QR Code para começar a usar o sistema.
    </div>

    <!-- 📱 Sessões -->
    <section class="card">
      <h2><i class="fa-solid fa-server"></i> Sessões</h2>
      <div id="sessions-list"></div>
    </section>

  </main>

  <footer>
    © 2026 ZapConnect — Todos os direitos reservados.<br>
    Desenvolvido por <a href="https://www.instagram.com/vini__n10?igsh=NzF4am94bjhmdHJ6" target="_blank">Vinicius Souza</a>
  </footer>

  <script src="/js/index.js"></script>
  <script src="/js/config.js"></script>

  <script>
    function goToChat() {
        // Verificar se há sessão conectada antes de ir para o chat
        const sessions = window._cachedSessions || [];
        const connected = sessions.some(s => s.status === "connected");

        if (!connected) {
            if (typeof notify === "function") {
                notify("Nenhum WhatsApp conectado. Crie e escaneie uma sessão primeiro.", "warning");
            } else {
                alert("Nenhum WhatsApp conectado. Crie e escaneie uma sessão primeiro.");
            }
            // Scroll até a seção de sessões para facilitar
            document.getElementById("sessions-list")
                ?.scrollIntoView({ behavior: "smooth" });
            return;
        }

        location.href = "/chat";
    }

    function goToDisparo() { location.href = "/disparo"; }
    function goToAgendamentos() { location.href = "/agendamentos"; }
    function goToSessions() {
      document.getElementById("sessions-list")
        ?.scrollIntoView({ behavior: "smooth" });
    }
  </script>

</body>

</html>
